    "prepare": "husky"
  },
  "dependencies": {
    "@stringzhao/auth-sdk": "^0.1.1",
    "@types/pg": "^8.18.0",
    "@upstash/redis": "^1.34.9",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "lru-cache": "^11.2.2",
    "next": "^15.2.4",
    "pg": "^8.19.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rss-parser": "^3.13.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.13.10",

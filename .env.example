# ============================================
# ai-news 环境变量模板
# 复制为 .env.local 并填入实际值
# ============================================

# --- 核心 ---
ARTICLE_DB_BASE_URL="https://your-article-db.example.com"
ARTICLE_DB_API_TOKEN="your-article-db-api-token"
CRON_SECRET="your-cron-secret"

# --- 数据库 (Neon Postgres) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- DeepSeek LLM ---
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# --- flomo ---
FLOMO_API_URL="https://flomoapp.com/iwh/your-webhook-path/"

# --- Tracker ---
TRACKER_BASE_URL="https://your-tracker-base-url"
TRACKER_SIGNING_SECRET="your-tracker-signing-secret"
TRACKER_API_TOKEN="your-tracker-api-token"

# --- 统一认证 (Unified Auth) ---
AUTH_ISSUER="https://user.stringzhao.life"
NEXT_PUBLIC_AUTH_ISSUER="https://user.stringzhao.life"
NEXT_PUBLIC_AUTH_AUTHORIZE_PATH="/authorize"
NEXT_PUBLIC_AUTH_CALLBACK_PATH="/auth/callback"
NEXT_PUBLIC_AUTH_ME_PATH="/api/auth/me"
NEXT_PUBLIC_AUTH_LOGOUT_PATH="/api/auth/logout"

# --- Redis / KV (Upstash) ---
KV_REST_API_URL="https://your-upstash-instance.upstash.io"
KV_REST_API_TOKEN="your-upstash-token"
UPSTASH_REDIS_REST_URL="https://your-upstash-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# --- 前端 ---
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3721"

# --- 个性化 (可选，有默认值) ---
# PERSONALIZATION_ENABLED="true"
# PERSONALIZATION_HALF_LIFE_DAYS="21"
# PERSONALIZATION_LOOKBACK_DAYS="90"
# DIGEST_TIMEZONE="Asia/Shanghai"
